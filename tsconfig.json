{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"lib": [ "DOM", "DOM.Iterable", "ES2021" ],
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [ "wordpress/plugins/enterprise-publishing/blocks/**/*" ]
}
