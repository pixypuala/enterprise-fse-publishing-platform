{
    "name": "pixypuala/enterprise-fse-publishing-platform",
    "description": "Enterprise Full Site Editing publishing platform for WordPress: governed content models, capabilities, and a swappable FSE block theme.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pixypuala\\EnterprisePublishing\\": "wordpress/plugins/enterprise-publishing/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixypuala\\EnterprisePublishing\\Tests\\": "tests/unit/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    }
}
