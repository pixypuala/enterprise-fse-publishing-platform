{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "42rem",
			"wideSize": "76rem"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": false,
			"palette": [
				{ "slug": "base", "color": "#faf9f6", "name": "Base" },
				{ "slug": "surface", "color": "#ffffff", "name": "Surface" },
				{ "slug": "contrast", "color": "#141b24", "name": "Contrast" },
				{ "slug": "muted", "color": "#5a6572", "name": "Muted" },
				{ "slug": "accent", "color": "#0b5d4e", "name": "Accent" },
				{ "slug": "accent-strong", "color": "#083f36", "name": "Accent strong" },
				{ "slug": "line", "color": "#e3e0d8", "name": "Line" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display",
					"fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, \"URW Palladio L\", Georgia, serif"
				},
				{
					"slug": "body",
					"name": "Body",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Helvetica Neue\", Helvetica, Arial, sans-serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"SFMono-Regular\", ui-monospace, \"Cascadia Mono\", Menlo, Consolas, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem", "fluid": false },
				{ "slug": "medium", "name": "Medium", "size": "1.05rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "large", "name": "Large", "size": "1.5rem", "fluid": { "min": "1.35rem", "max": "1.75rem" } },
				{ "slug": "x-large", "name": "Extra large", "size": "2.25rem", "fluid": { "min": "1.9rem", "max": "2.75rem" } },
				{ "slug": "xx-large", "name": "Display", "size": "3.5rem", "fluid": { "min": "2.6rem", "max": "4.25rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "20", "name": "1", "size": "0.5rem" },
				{ "slug": "30", "name": "2", "size": "1rem" },
				{ "slug": "40", "name": "3", "size": "1.5rem" },
				{ "slug": "50", "name": "4", "size": "2.5rem" },
				{ "slug": "60", "name": "5", "size": "4rem" },
				{ "slug": "70", "name": "6", "size": "6rem" }
			]
		},
		"custom": {
			"radius": {
				"card": "0.5rem",
				"control": "0.375rem"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--40)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--40)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "1.15"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				"typography": { "textDecoration": "underline" },
				":hover": { "color": { "text": "var(--wp--preset--color--accent-strong)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--surface)"
				},
				"border": { "radius": "var(--wp--custom--radius--control)" },
				"spacing": { "padding": { "top": "0.75rem", "right": "1.5rem", "bottom": "0.75rem", "left": "1.5rem" } },
				"typography": { "fontWeight": "600" },
				":hover": { "color": { "background": "var(--wp--preset--color--accent-strong)" } }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-no-title", "title": "Page (no title)", "postTypes": [ "page" ] }
	]
}
