<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit configuration for the pure-domain unit suite.

  These tests exercise framework-free domain classes (content models,
  capability policy, migration ledger) and therefore need NO WordPress install,
  keeping the core policy fast to verify in CI.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnWarning="true"
         failOnRisky="true"
         beStrictAboutOutputDuringTests="true">
    <testsuites>
        <testsuite name="unit">
            <directory>tests/unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">wordpress/plugins/enterprise-publishing/src</directory>
        </include>
    </source>
</phpunit>
